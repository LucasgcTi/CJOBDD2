CREATE TABLE Clientes (
    ID INTEGER PRIMARY KEY,
    Nome VARCHAR,
    CPF INTEGER,
    RG INTEGER,
    Telefone INTEGER,
    Email VARCHAR,
    Endereco VARCHAR
);

CREATE TABLE Funcionario (
    id_funcionario INTEGER PRIMARY KEY,
    Nome VARCHAR,
    Cargo VARCHAR,
    CPF INTEGER,
    Telefone INTEGER,
    Salario INTEGER,
    Data_admissao INTEGER,
    fk_Atendimento_id_atendimento INTEGER
);

CREATE TABLE Documento (
    id_documento INTEGER PRIMARY KEY,
    tipo_documento VARCHAR,
    numero_documento INTEGER,
    data_emissao INTEGER,
    orgao_emissor VARCHAR,
    fk_Clientes_ID INTEGER
);

CREATE TABLE Atendimento (
    id_atendimento INTEGER PRIMARY KEY,
    data_atendimento INTEGER,
    tipo_servico VARCHAR,
    valor INTEGER,
    status_atendimento VARCHAR,
    fk_Clientes_ID INTEGER
);

CREATE TABLE Registro (
    id_registro INTEGER PRIMARY KEY,
    tipo_registro VARCHAR,
    livro INTEGER,
    folha INTEGER,
    termo VARCHAR,
    data_registro INTEGER,
    fk_Atendimento_id_atendimento INTEGER
);
 
